class Solution {
    public int lengthOfLongestSubstring(String s) {
        int maxLen = 0;

        for (int i = 0; i < s.length(); i++) {
            HashSet<Character> map = new HashSet<>();

            for (int j = i; j < s.length(); j++) {
                char ch = s.charAt(j);

                if (map.contains(ch)) {
                    break;
                }
                map.add(ch);
                maxLen = Math.max(maxLen, j - i + 1);
            }
        }
        return maxLen;
    }
}
