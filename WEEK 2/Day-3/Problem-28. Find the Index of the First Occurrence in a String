class Solution {
    public int strStr(String haystack, String needle) {
        if(needle.length()>haystack.length()){
            return -1;
        }
        int i=0;
        int j=0;
        while(i<=haystack.length() - needle.length()){
            for(j=0;j<needle.length();j++){
                if(haystack.charAt(i+j)==needle.charAt(j)){
                    continue;
                }
                else{
                    break;
                }
            }
            if(j==needle.length()){
                return i;
            }
            i++;
        }
        return -1;
    }
}
